            "options": [
                "TCP",
                "UDP",
                "ICMP",
                "Other"
            ],
            "value": "TCP"
        },
        "severity": {
            "type": "input_select",
            "mandatory": false,
            "options": [
                "Low",
                "Medium",
                "High"
            ],
