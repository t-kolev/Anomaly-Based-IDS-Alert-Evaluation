        "dest_port": {
            "type": "input_string",
            "mandatory": false,
            "value": ""
        },
        "event_type": {
            "type": "input_string",
            "mandatory": false,
            "value": "alert"
        },
        "pkt_src": {
            "type": "input_string",
            "mandatory": false,
            "value": ""
        },
        "category": {
            "type": "input_string",
